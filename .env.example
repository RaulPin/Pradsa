# Copy this file to .env and fill in real values before starting the server.
# .env is gitignored — never commit real secrets.

# REQUIRED: Secret used to sign JWT tokens.
# Generate a strong random value, e.g.:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# Optional: HTTP port (default 3000)
# PORT=3000
