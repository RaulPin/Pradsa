# ============================================================
#  EntrevistasPradsa – Configuración de entorno
#  Copia este archivo como .env y completa los valores
# ============================================================

# ------- JWT -----------------------------------------------
# Genera un secreto aleatorio de 64+ caracteres:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO_DE_64_CARACTERES_MINIMO

# ------- Servidor ------------------------------------------
PORT=3000
NODE_ENV=production
APP_URL=https://entrevistas.tudominio.com

# ------- Base de datos -------------------------------------
DB_PATH=./data/entrevistaspradsa.db

# ------- Almacenamiento de fotos ---------------------------
UPLOAD_DIR=./uploads/photos

# ------- SMTP (servidor de correo propio) ------------------
SMTP_HOST=mail.tudominio.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=contraseña_smtp
SMTP_FROM=EntrevistasPradsa <notificaciones@tudominio.com>

# ------- Usuario administrador inicial ---------------------
# Se crea automáticamente la primera vez que arranca el servidor
# La contraseña temporal se imprime en consola
ADMIN_EMAIL=admin@tudominio.com
ADMIN_NAME=Administrador
